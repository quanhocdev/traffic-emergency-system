# CanhBaoSuCo/.env.example

# ========================
# DATABASE CONFIG
# ========================
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=your_database_name
MYSQL_USER=your_username
MYSQL_PASSWORD=your_password

DB_PORT=3306

# ========================
# JWT CONFIG
# ========================
JWT_SECRET=your_jwt_secret_key_here
JWT_ACCESS_EXPIRATION = your_time_in_milliseconds_for_access_token
JWT_REFRESH_EXPIRATION = your_time_in_milliseconds_for_refresh_token
# ========================
# GEMINI API
# ========================
GEMINI_API_KEYS=your_api_key_1,your_api_key_2,your_api_key_3